# AI Test Hub 环境变量配置
# 复制此文件为 .env 并填入实际值

# Flask 配置
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here-change-in-production

# 数据库配置 (SQLite 默认路径)
DATABASE_URL=sqlite:///ai_test_hub.db

# AI 模型 API Keys
CSDN_API_KEY=sk-ffpztriquewtxvay
GITCODE_API_KEY=your-gitcode-key-here

# 上传配置
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# SocketIO 配置
SOCKETIO_ASYNC_MODE=eventlet

# 用户配置 (简易协作)
DEFAULT_USER=admin